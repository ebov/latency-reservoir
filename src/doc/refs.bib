@ARTICLE{Formenty2003-hv,
  title    = "Outbreak of Ebola hemorrhagic fever in the Republic of the Congo,
              2003: a new strategy?",
  author   = "Formenty, P and Libama, F and Epelboin, A and Allarangar, Y and
