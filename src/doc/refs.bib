@ARTICLE{Rambaut2016-gr,
  title    = "Exploring the temporal structure of heterochronous sequences using
              {TempEst} (formerly Path-{O}-Gen)",
  author   = "Rambaut, Andrew and Lam, Tommy T and Max Carvalho, Luiz and Pybus,
              Oliver G",
  journal  = "Virus Evol",
  volume   =  2,
  number   =  1,
  pages    = "vew007",
  abstract = "Gene sequences sampled at different points in time can be used to
              infer molecular phylogenies on a natural timescale of months or
              years, provided that the sequences in question undergo measurable
              amounts of evolutionary change between sampling times. Data sets
              with this property are termed heterochronous and have become
              increasingly common in several fields of biology, most notably the
              molecular epidemiology of rapidly evolving viruses. Here we
              introduce the cross-platform software tool, TempEst (formerly
              known as Path-O-Gen), for the visualization and analysis of
              temporally sampled sequence data. Given a molecular phylogeny and
              the dates of sampling for each sequence, TempEst uses an
