@ARTICLE{Baize2014-hp,
  title     = "Emergence of Zaire Ebola virus disease in Guinea",
  author    = "Baize, Sylvain and Pannetier, Delphine and Oestereich, Lisa and
               Rieger, Toni and Koivogui, Lamine and Magassouba, N'faly and
