@ARTICLE{Riesle-Sbarbaro2024-iz,
  title    = "Selective replication and vertical transmission of Ebola virus in
              experimentally infected Angolan free-tailed bats",
  author   = "Riesle-Sbarbaro, S A and Wibbelt, G and Düx, A and Kouakou, V and
