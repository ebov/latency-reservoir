@ARTICLE{Wertheim2009-uq,
  title     = "Relaxed selection and the evolution of {RNA} virus mucin-like
               pathogenicity factors",
  author    = "Wertheim, Joel O and Worobey, Michael",
  journal   = "J. Virol.",
  publisher = "American Society for Microbiology",
  volume    =  83,
  number    =  9,
  pages     = "4690--4694",
  abstract  = "Mucin-like regions contribute to pathogenicity in a variety of
               negative-stranded RNA viruses. These regions are characterized by
               a preponderance of O-linked glycosylation. They evolve
               exceptionally rapidly yet maintain their function as
               pathogenicity factors. Two hypotheses have been proposed to
               explain this evolutionary conundrum of phenotypic stability in
               the face of extreme genetic divergence: strong positive selection
               and relaxation of purifying selection. We determined the strength
               and direction of selection codon by codon across genes containing
               these regions and found that purifying selection is relaxed over
               the mucin-like regions relative to the genes in which they are
               found. This suggests that so long as these regions maintain
               sufficient O-linked glycosylation, they are free to evolve
               rapidly without loss of function as pathogenicity factors.",
  month     =  may,
  year      =  2009,
  language  = "en"
}

@ARTICLE{Wittmann2007-hm,
  title     = "Isolates of Zaire ebolavirus from wild apes reveal genetic
               lineage and recombinants",
  author    = "Wittmann, Tatiana J and Biek, Roman and Hassanin, Alexandre and
               Rouquet, Pierre and Reed, Patricia and Yaba, Philippe and
               Pourrut, Xavier and Real, Leslie A and Gonzalez, Jean-Paul and
               Leroy, Eric M",
  journal   = "Proc. Natl. Acad. Sci. U. S. A.",
  publisher = "Proceedings of the National Academy of Sciences",
  volume    =  104,
  number    =  43,
  pages     = "17123--17127",
  abstract  = "Over the last 30 years, Zaire ebolavirus (ZEBOV), a virus highly
               pathogenic for humans and wild apes, has emerged repeatedly in
               Central Africa. Thus far, only a few virus isolates have been
               characterized genetically, all belonging to a single genetic
               lineage and originating exclusively from infected human patients.
               Here, we describe the first ZEBOV sequences isolated from great
               ape carcasses in the Gabon/Congo region that belong to a
               previously unrecognized genetic lineage. According to our
               estimates, this lineage, which we also encountered in the two
               most recent human outbreaks in the Republic of the Congo in 2003
               and 2005, diverged from the previously known viruses around the
               time of the first documented human outbreak in 1976. These
               results suggest that virus spillover from the reservoir has
               occurred more than once, as predicted by the multiple emergence
               hypothesis. However, the young age of both ZEBOV lineages and the
               spatial and temporal sequence of outbreaks remain at odds with
               the idea that the virus simply emerged from a long-established
               and widespread reservoir population. Based on data from two ZEBOV
               genes, we also demonstrate, within the family Filoviridae,
               recombination between the two lineages. According to our
               estimates, this event took place between 1996 and 2001 and gave
               rise to a group of recombinant viruses that were responsible for
               a series of outbreaks in 2001-2003. The potential for
               recombination adds an additional level of complexity to
               unraveling and potentially controlling the emergence of ZEBOV in
               humans and wildlife species.",
  month     =  oct,
  year      =  2007,
  language  = "en"
}

@ARTICLE{Lahm2007-ug,
  title     = "Morbidity and mortality of wild animals in relation to outbreaks
               of Ebola haemorrhagic fever in Gabon, 1994-2003",
  author    = "Lahm, Sally A and Kombila, Maryvonne and Swanepoel, Robert and
