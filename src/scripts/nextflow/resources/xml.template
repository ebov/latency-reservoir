			<parameter idref="set19.cds1.frequencies"/>
		</deltaExchange>
		<scaleOperator scaleFactor="0.75" weight="1">
			<parameter idref="set19.cds2.kappa"/>
		</scaleOperator>
		<deltaExchange delta="0.01" weight="1">
			<parameter idref="set19.cds2.frequencies"/>
		</deltaExchange>
		<scaleOperator scaleFactor="0.75" weight="1">
			<parameter idref="set19.cds3_ig.kappa"/>
		</scaleOperator>
		<deltaExchange delta="0.01" weight="1">
			<parameter idref="set19.cds3_ig.frequencies"/>
		</deltaExchange>
		<scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="clock.rate"/>
		</scaleOperator>
        %if local_clock:
        <scaleOperator scaleFactor="0.75" weight="3">
			<parameter idref="NordDRC.rate"/>
		</scaleOperator>
        %endif
		<upDownOperator scaleFactor="0.75" weight="3">
			<up>
				<parameter idref="treeModel.allInternalNodeHeights"/>
			</up>
			<down>
				<parameter idref="clock.rate"/>
			</down>
		</upDownOperator>
		<deltaExchange delta="0.01" weight="3">
			<parameter idref="allNus"/>
		</deltaExchange>
		<subtreeLeap size="1.0" weight="${branch_count*10}">
			<treeModel idref="treeModel"/>
		</subtreeLeap>
		<fixedHeightSubtreePruneRegraft weight="3">
			<treeModel idref="treeModel"/>
		</fixedHeightSubtreePruneRegraft>
		<scaleOperator scaleFactor="0.75" weight="3">
				<parameter idref="exponential.popSize"/>
		</scaleOperator>

		<randomWalkOperator windowSize="1.0" weight="3">
				<parameter idref="exponential.growthRate" />
		</randomWalkOperator>
		<!-- START latent clock model -->

		<scaleOperator scaleFactor="0.75" weight="3">
	        <parameter idref="latentStateRate"/>
		</scaleOperator>

		<randomWalkOperator windowSize="0.05" weight="10" boundaryCondition="logit">
			<parameter idref="latentStateProportions"/>
		</randomWalkOperator>
		<randomWalkOperator windowSize="0.05" weight="13" boundaryCondition="logit">
					<parameter idref="latentStateBias"/>
		</randomWalkOperator> 
        %if sum_prior:
        <bitFlipOperator weight="10">
			<parameter idref="latentStateIndicators"/>
		</bitFlipOperator>
        %else:
		<bitFlipOperator weight="10"  usesPriorOnSum="false">
			<parameter idref="latentStateIndicators"/>
		</bitFlipOperator>
        %endif

		<!-- END latent clock model -->
		<uniformOperator weight="1">
			<parameter idref="age(KC242793|1Eko|Gabon|1996-02)"/>
		</uniformOperator>
		<uniformOperator weight="1">
			<parameter idref="age(KC242791|Bonduni|DRC|1977-06)"/>
		</uniformOperator>
		<uniformOperator weight="1">
			<parameter idref="age(MH613311|Muembe.1|DRC|2017-05)"/>
		</uniformOperator>
		<uniformOperator weight="1">
			<parameter idref="age(KF113529|Kelle_2|COG|2003-10)"/>
		</uniformOperator>
	</operators>
	

	<!-- Define MCMC                                                             -->
	<mcmc id="mcmc" chainLength="${chain_length}" autoOptimize="true" operatorAnalysis="${base_name}.ops">
		<joint id="joint">
			<prior id="prior">
                %if local_clock:
                    <booleanLikelihood>
					    <monophylyStatistic idref="monophyly(NordDRC)"/>
				    </booleanLikelihood>
                %endif
				<logNormalPrior mu="1.0" sigma="1.25" offset="0.0">
					<parameter idref="set19.cds1.kappa"/>
				</logNormalPrior>
				<dirichletPrior alpha="1.0" sumsTo="1.0">
					<parameter idref="set19.cds1.frequencies"/>
				</dirichletPrior>
				<logNormalPrior mu="1.0" sigma="1.25" offset="0.0">
					<parameter idref="set19.cds2.kappa"/>
				</logNormalPrior>
				<dirichletPrior alpha="1.0" sumsTo="1.0">
					<parameter idref="set19.cds2.frequencies"/>
				</dirichletPrior>
				<logNormalPrior mu="1.0" sigma="1.25" offset="0.0">
					<parameter idref="set19.cds3_ig.kappa"/>
				</logNormalPrior>
				<dirichletPrior alpha="1.0" sumsTo="1.0">
					<parameter idref="set19.cds3_ig.frequencies"/>
				</dirichletPrior>
				<dirichletPrior alpha="1.0" sumsTo="1.0">
					<parameter idref="allNus"/>
				</dirichletPrior>
                %if local_clock:

				<laplacePrior scale="5.0" mean="10.575" > <!-- origin =  2020-06-12 (ml branch length for 2018 sample = 8.7 years) mean at 2009.97 )-->
					<tmrcaStatistic idref="tmrca(NordDRC)"/>
				</laplacePrior>
                <ctmcScalePrior>
					<ctmcScale>
						<parameter idref="clock.rate"/>
					</ctmcScale>
					<taxa>
						<taxa idref="taxa"/>
						<exclude>
							<taxa idref="NordDRC"/>
						</exclude>
					</taxa>
					<treeModel idref="treeModel"/>
				</ctmcScalePrior>
				
				<ctmcScalePrior>
					<ctmcScale>
						<parameter idref="NordDRC.rate"/>
					</ctmcScale>
					<taxa idref="NordDRC"/>
					<treeModel idref="treeModel"/>
				</ctmcScalePrior>
                %else:
				<ctmcScalePrior>
					<ctmcScale>
						<parameter idref="clock.rate"/>
					</ctmcScale>
					<treeModel idref="treeModel"/>
				</ctmcScalePrior>
                %endif
				<gammaPrior shape="0.001" scale="1000" offset="0.0">
					<parameter idref="exponential.popSize"/>
				</gammaPrior>
	
				<laplacePrior scale="100.0" mean="0.0">
					<parameter idref="exponential.growthRate"/>
				</laplacePrior>
				<coalescentLikelihood idref="coalescent"/>
			<!-- START latent clock model -->
				<uniformPrior upper="1.0" lower="0.0">
					<parameter idref="latentStateBias"/>
				</uniformPrior> 
				<exponentialPrior mean="0.075"  offset="0.0" id="latentRatePrior">
					<parameter idref="latentStateRate"/>
				</exponentialPrior>

				<latentStateBranchRateModel idref="latent.branchRates"/>
				%if sum_prior:
                <uniformPrior lower="0.0" upper="${branch_count/2}">
                    <statistic idref="nonZeroIndicators"/>
                </uniformPrior>
                %endif
			<!-- END latent clock model -->
				<strictClockBranchRates idref="branchRates"/>
			</prior>
			<likelihood id="likelihood">
				<treeDataLikelihood idref="treeLikelihood"/>
			</likelihood>
		</joint>
		<operators idref="operators"/>

		<!-- write log to screen                                                     -->
		<log id="screenLog" logEvery="10000">
			<column label="Joint" dp="4" width="12">
				<joint idref="joint"/>
			</column>
			<column label="Prior" dp="4" width="12">
				<prior idref="prior"/>
			</column>
			<column label="Likelihood" dp="4" width="12">
				<likelihood idref="likelihood"/>
			</column>
			<column label="age(root)" sf="6" width="12">
				<tmrcaStatistic idref="age(root)"/>
			</column>
			<column label="clock.rate" sf="6" width="12">
				<parameter idref="clock.rate"/>
			</column>
		<!-- START latent clock model -->
			<column label="latent.rate" sf="6" width="12">
				<parameter idref="latentStateRate"/>
			</column>
			<column label="indicators" dp="1" width="4">
			 	<statistic idref="nonZeroIndicators"/>
			 </column>
		<!-- END latent clock model -->
		</log>

		<!-- write log to file                                                       -->
		<log id="fileLog" logEvery="${log_every}" fileName="${base_name}.log" overwrite="false">
			<joint idref="joint"/>
			<prior idref="prior"/>
			<likelihood idref="likelihood"/>
			<treeHeightStatistic idref="rootHeight"/>
			<tmrcaStatistic idref="age(root)"/>
            %if local_clock:
            <tmrcaStatistic idref="tmrca(NordDRC)"/>
            %endif
			<treeLengthStatistic idref="treeLength"/>
			<parameter idref="exponential.popSize"/>
			<parameter idref="exponential.growthRate"/>
			<parameter idref="set19.cds1.kappa"/>
			<parameter idref="set19.cds1.frequencies"/>
			<parameter idref="set19.cds2.kappa"/>
			<parameter idref="set19.cds2.frequencies"/>
			<parameter idref="set19.cds3_ig.kappa"/>
			<parameter idref="set19.cds3_ig.frequencies"/>
			<compoundParameter idref="allNus"/>
			<statistic idref="set19.cds1.mu"/>
			<statistic idref="set19.cds2.mu"/>
			<statistic idref="set19.cds3_ig.mu"/>
			<parameter idref="clock.rate"/>
			<!-- START latent clock model -->
			<rateStatistic idref="meanRate"/>
			<rateStatistic idref="coefficientOfVariation"/>
			<rateCovarianceStatistic idref="covariance"/>

			<statistic idref="nonZeroIndicators"/>
			<parameter idref="latentStateRate"/>
			<parameter idref="latentStateBias"/>
			<!-- END latent clock model -->
			<!-- START Tip date sampling                                                 -->
			<parameter idref="age(KC242793|1Eko|Gabon|1996-02)"/>
			<parameter idref="age(KC242791|Bonduni|DRC|1977-06)"/>
			<parameter idref="age(MH613311|Muembe.1|DRC|2017-05)"/>
			<parameter idref="age(KF113529|Kelle_2|COG|2003-10)"/>

			<!-- END Tip date sampling                                                   -->

			<treeDataLikelihood idref="treeLikelihood"/>
			<latentStateBranchRateModel idref="latent.branchRates"/>
			<strictClockBranchRates idref="branchRates"/>
			<coalescentLikelihood idref="coalescent"/>
		</log>

		<!-- write tree log to file                                                  -->
		<logTree id="treeFileLog" logEvery="${log_every}" nexusFormat="true" fileName="${base_name}.trees" sortTranslationTable="true">
			<treeModel idref="treeModel"/>
	<!-- START latent clock model -->
			<trait name="rate" tag="rate">
    			<latentStateBranchRateModel idref="latent.branchRates"/>
			</trait>
			<trait name="proportions" tag="LS">
    			<latentStateBranchRateModel idref="latent.branchRates"/>
			</trait>
	<!-- END latent clock model -->
			<joint idref="joint"/>
		</logTree>

		<!-- write state of Markov chain to checkpoint file                          -->
	</mcmc>
	
	<report>
		<property name="timer">
			<mcmc idref="mcmc"/>
		</property>
	</report>
	
</beast>
